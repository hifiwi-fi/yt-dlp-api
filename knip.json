{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignore": [],
  "ignoreBinaries": ["python3", "pip3", "flask", "gunicorn"],
  "ignoreUnresolved": [],
  "ignoreDependencies": ["@types/jsdom"],
  "entry": [
    "app.js",
    "otel.js",
    "config/**/*.js",
    "lib/**/*.js",
    "plugins/**/*.js",
    "routes/**/*.js",
    "test/**/*.js",
    "types/**/*.ts"
  ],
  "project": ["**/*.js", "**/*.ts", "**/*.d.ts"]
}
